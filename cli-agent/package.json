    "execa": "^9.3.0",
    "fast-glob": "^3.3.2"
  },
  "devDependencies": {
    "@types/diff": "^5.2.1",
    "@types/node": "^20.14.11",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
